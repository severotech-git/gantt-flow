# ─── Database
MONGODB_URI=mongodb://user:pass@localhost:27017/ganttflow?authSource=admin

# ─── NextAuth
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Your app's public URL (used in authentication links and OAuth redirects)
NEXTAUTH_URL=http://localhost:3000

# ─── OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── SMTP / Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false          # true for port 465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com

# ─── Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads Conversion Tracking
NEXT_PUBLIC_GADS_CONVERSION_ID=AW-XXXXXXXXXX
NEXT_PUBLIC_GADS_CONVERSION_LABEL=xxxxxxxxxxxxxx
